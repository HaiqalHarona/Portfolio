---
// src/pages/nino.astro
import BaseHead from "../components/BaseHead.astro";
import { ViewTransitions } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION, TRANSITION_API } from "../config";
import "sakura-js/dist/sakura.css";
---

<!doctype html>
<html lang="en" data-theme="lofi">
  <head>
    <BaseHead title={`CLASSIFIED - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
    {TRANSITION_API && <ViewTransitions />}
  </head>
  <body class="bg-[#10090c] text-white relative min-h-screen overflow-x-hidden">
    <div id="petal-container" class="fixed inset-0 pointer-events-none z-[1] overflow-hidden"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-8 font-mono min-h-screen flex flex-col relative pt-4 pb-2 z-10">
    
    <!-- Page Header -->
    <div class="mt-2 mb-3 boot-sequence z-10" style="--delay: 0ms;">
      <h1 class="text-3xl md:text-4xl font-bold text-[#ff80bf] mb-1 flex items-center tracking-tighter">
        Nino Nakano
      </h1>
      <p class="text-xs md:text-sm opacity-80 text-[#ffb3d9]">Because someone had to make a dedicated page for the best quintuplet.</p>
    </div>

    <!-- MAIN UI GRID (Inspired by Anime UI Layouts) -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 relative z-10 mt-4 flex-grow">
      
      <!-- LEFT COLUMN: Profile & Lore -->
      <div class="md:col-span-3 flex flex-col gap-6 boot-sequence" style="--delay: 200ms;">
        
        <!-- Profile Panel -->
        <div class="border border-[#ff80bf]/30 bg-[#1a0f14]/80 backdrop-blur-md rounded-md p-4">
          <div class="flex items-center gap-4 mb-4">
            <!-- AVATAR -->
            <img 
              src="/images/link/popup-pfp.png" 
              alt="Profile Avatar" 
              class="w-16 h-16 rounded-full border-2 border-[#ff80bf] object-cover"
            />
            <div>
              <h2 class="text-[#ff80bf] font-bold">Nino Nakano</h2>
              <p class="text-xs text-white/50">@TheUnstoppableTrain</p>
            </div>
          </div>
          <div class="flex gap-2">
            <button id="like-btn" class="flex-1 bg-[#2d1a24] border border-[#ff80bf]/30 text-white/70 text-xs py-1.5 hover:bg-[#ff80bf]/20 hover:text-[#ff80bf] transition-colors relative overflow-hidden group">
              <span class="relative z-10 flex items-center justify-center gap-2 font-sans font-semibold">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5 group-hover:scale-125 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
                Like
              </span>
            </button>
          </div>
        </div>

        <!-- Lore/Stats Panel -->
        <div class="border border-[#ff80bf]/30 bg-[#1a0f14]/80 backdrop-blur-md rounded-md overflow-hidden">
          <div class="bg-[#2d1a24] px-3 py-1.5 text-[10px] text-[#ff80bf] border-b border-[#ff80bf]/20 uppercase tracking-widest">
            > cat about.txt
          </div>
          <div class="p-4 text-xs text-[#ffb3d9]/80 leading-relaxed space-y-2">
            <p>Instance 02 of the Nakano Quintuplet series. Highly volatile tsundere architecture.</p>
            <p>Known for aggressive frontend styling and unmatched loyalty protocols once trust metrics are verified.</p>
          </div>
        </div>

        <!-- Terminal Execution Panel -->
        <div class="border border-[#ff80bf]/30 bg-[#1a0f14]/80 backdrop-blur-md rounded-md overflow-hidden stdout-container">
          <div class="bg-[#2d1a24] px-3 py-1.5 text-[10px] text-[#ffb3d9]/70 border-b border-[#ff80bf]/20 flex items-center justify-between">
            <div class="flex items-center">
              <div class="flex space-x-1 mr-2">
                <div class="w-2 h-2 rounded-full bg-[#ff4d4d]"></div>
                <div class="w-2 h-2 rounded-full bg-[#ffcc00]"></div>
                <div class="w-2 h-2 rounded-full bg-[#ff80bf]"></div>
              </div>
              <span>./protocol.sh</span>
            </div>
          </div>
          
          <div class="p-4 text-[11px]">
            <p class="leading-relaxed text-[#ffb3d9] mb-3">
              <span class="text-[#ff80bf] font-bold mr-1">></span>
              <span class="stdout-line">Init Tsundere_Protocol... [OK]</span>
            </p>
            <p class="leading-relaxed text-[#ffb3d9] mb-3 stdout-line">
              > Culinary skills loaded.<br/>
              > Aesthetic override: PINK.<br/>
              > Bypassing firewalls...
            </p>
            <p class="leading-relaxed text-white stdout-line border-l-2 border-[#ff80bf] pl-3 italic bg-[#ff80bf]/5 py-2 mt-2">
              "It's not like I wanted you to find this page or anything! Don't get the wrong idea!"
            </p>
          </div>
        </div>

        <!-- Niche Back Button -->
        <div class="mt-2 text-xs font-mono opacity-50 hover:opacity-100 transition-opacity">
          <a href="/about-me" class="flex items-center gap-2 text-white/70 hover:text-[#ff80bf] transition-colors w-fit group">
            <span class="text-[#ff80bf] opacity-0 group-hover:opacity-100 transition-opacity">></span> 
            <span class="underline decoration-[#ff80bf]/30 underline-offset-4">exit && cd ~</span>
          </a>
        </div>
      </div>

      <!-- CENTER COLUMN: The Main Character Mask -->
      <!-- MASK PLACEHOLDER: Use a transparent PNG (no background) of the character -->
      <div class="md:col-span-6 relative flex justify-center items-end min-h-[400px] md:min-h-[550px] boot-sequence" style="--delay: 400ms;">
        <img 
          src="/images/link/splashart.png" 
          alt="Main Character Render" 
          class="relative z-10 w-[110%] max-w-[110%] h-auto max-h-[75vh] object-contain hover:scale-105 transition-all duration-700 mb-8 md:mb-24"
        />
      </div>

      <!-- RIGHT COLUMN: Gallery & Terminal -->
      <div class="md:col-span-3 flex flex-col gap-6 boot-sequence" style="--delay: 600ms;">
        
        <!-- Gallery Panel -->
        <div class="border border-[#ff80bf]/30 bg-[#1a0f14]/80 backdrop-blur-md rounded-md p-2">
          <!-- GALLERY -->
          <img 
            src="/images/link/Compressed.png" 
            alt="Gallery Scene" 
            class="w-full h-auto rounded border border-[#ff80bf]/20 grayscale-[50%] hover:grayscale-0 transition-all duration-300 object-cover"
          />
          <div class="mt-2 px-2 pb-1">
            <p class="text-[10px] text-[#ff80bf] uppercase tracking-widest">> Current Mood</p>
            <p class="text-xs text-white/70 mt-1">Hostile, but plotting a confession.</p>
          </div>
        </div>

        <!-- Facts Terminal Panel -->
        <div class="border border-[#ff80bf]/30 bg-[#1a0f14]/80 backdrop-blur-md rounded-md overflow-hidden stdout-container">
          <div class="bg-[#2d1a24] px-3 py-1.5 text-[10px] text-[#ffb3d9]/70 border-b border-[#ff80bf]/20 flex items-center justify-between">
            <div class="flex items-center">
              <div class="flex space-x-1 mr-2">
                <div class="w-2 h-2 rounded-full bg-[#ff4d4d]"></div>
                <div class="w-2 h-2 rounded-full bg-[#ffcc00]"></div>
                <div class="w-2 h-2 rounded-full bg-[#ff80bf]"></div>
              </div>
              <span>cat facts.txt</span>
            </div>
          </div>
          <div class="p-4">
            <p class="text-xs text-white/80 leading-relaxed text-justify stdout-line">
              <span class="text-[#ff80bf] font-bold mr-1">></span>In Season 1, she may not have seemed like the one. But in Season 2, she had the absolute <span class="text-[#ff80bf] font-bold">biggest character arc</span> of the series. She is undeniably the best girl of the five and by far the boldest quintuplet. When she makes her move, she doesn't miss.
            </p>
          </div>
        </div>

      </div>
    </div>
  </div>
  </body>
</html>

<script>
  // @ts-ignore
  import sakuraUrl from 'sakura-js/dist/sakura.js?url';

  document.addEventListener('astro:page-load', () => {
    // Sakura Initialization
    const s = document.createElement('script');
    s.src = sakuraUrl;
    s.onload = () => {
      // @ts-ignore
      new (window as any).Sakura('#petal-container', {
        colors: [
          {
            gradientColorStart: 'rgba(255, 183, 197, 0.9)',
            gradientColorEnd: 'rgba(255, 197, 208, 0.9)',
            gradientColorDegree: 120,
          }
        ]
      });
    };
    document.head.appendChild(s);

    // Like Button Heart Burst (dynamically import to avoid missing type declarations)
    const likeBtn = document.getElementById("like-btn");
    if (likeBtn) {
      likeBtn.addEventListener("click", function(e) {
        // @ts-ignore
        import('canvas-confetti').then((mod) => {
          const confetti = (mod && (mod.default || mod));
          if (typeof confetti === 'function') {
            confetti({
              particleCount: 40,
              spread: 90,
              origin: { y: 1.1 },
              startVelocity: 60,
              gravity: 0.8,
              ticks: 300,
              shapes: ['heart'],
              colors: ['FFC0CB', 'FF69B4', 'FF1493', 'C71585'],
              scalar: 2,
              zIndex: 9999
            });
          }
        }).catch(() => {});
      });
    }
  });
</script>
<script is:inline>
  document.addEventListener("astro:page-load", function() {

    // Stdout reveal animation
    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting && !entry.target.classList.contains("executed")) {
          entry.target.classList.add("executed");
          const lines = entry.target.querySelectorAll(".stdout-line");
          let delay = 0;
          lines.forEach(function(line) {
            setTimeout(function() {
              line.style.opacity = "1";
              line.style.visibility = "visible";
            }, delay);
            delay += 600;
          });
        }
      });
    });
    document.querySelectorAll(".stdout-container").forEach(function(c) {
      observer.observe(c);
    });


  });
</script>

<style>
  .stdout-line { opacity: 0; visibility: hidden; transition: opacity 0.4s; }
  
  .boot-sequence {
    opacity: 0;
    transform: translateY(10px);
    animation: fade-up 0.6s ease-out forwards;
    animation-delay: var(--delay);
  }
  
  @keyframes fade-up {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Global theme overrides just for this page */
  :global(body) {
    --b1: 20 15% 10%; /* Darker background with slight pink tint */
  }

</style>