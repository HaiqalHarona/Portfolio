---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { pb } from "../lib/pocketbase";

let featuredProjects: any[] = [];
try {
  const result = await pb.collection("projects").getList(1, 3, {
    filter: "is_featured = true",
    sort: "-created",
  });
  featuredProjects = result.items;
  if (featuredProjects.length === 0) {
    const fallback = await pb.collection("projects").getList(1, 3, {
      sort: "-created",
    });
    featuredProjects = fallback.items;
  }
} catch (e) {
  console.error("Failed to fetch featured projects from PocketBase:", e);
}
---

<BaseLayout sideBarActiveItemID="home" currentPath="/">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Your Name</div>
    <div class="text-3xl py-3 font-bold">Software Engineer & Developer</div>
    <div class="py-2">
      <text class="text-lg">
        Welcome to my personal portfolio. I build high-quality web applications and software solutions. 
        Feel free to browse my projects and professional resume.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="mailto:your.email@example.com"> Let's connect!</a>
      <a href="/cv" class="btn btn-outline ml-5">
        View Resume
      </a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">My last projects {"</>"}</div>
  </div>

  {featuredProjects.length === 0 ? (
    <p class="text-base-content/50 italic mb-5">No projects found.</p>
  ) : (
    featuredProjects.map((project) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.cover_image ? pb.files.getUrl(project, project.cover_image) : "/post_img.webp"}
          desc={project.description}
          url={`/projects/${project.id}`}
          badge={project.is_featured ? "Featured" : undefined}
        />
        <div class="divider my-0" />
      </>
    ))
  )}
</BaseLayout>

