---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { pb } from "../lib/pocketbase";

let projects: any[] = [];
try {
  projects = await pb.collection("projects").getFullList({
    sort: "-is_featured,-created",
  });
} catch (e) {
  console.error("Failed to fetch projects from PocketBase:", e);
}

const personalAndFun = projects.filter(p => p.project_type === "personal" || p.project_type === "forfun");
const schoolProjects = projects.filter(p => p.project_type === "school");
---

<BaseLayout title="Projects" sideBarActiveItemID="projects" currentPath="/projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Personal & Side Projects</div>
  </div>

  {personalAndFun.length === 0 ? (
    <p class="text-base-content/50 italic mb-5">No projects found.</p>
  ) : (
    personalAndFun.map((project) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.cover_image ? pb.files.getUrl(project, project.cover_image) : "/post_img.webp"}
          desc={project.description}
          url={`/projects/${project.id}`}
          badge={project.is_featured ? "Featured" : undefined}
        />
        <div class="divider my-0" />
      </>
    ))
  )}

  <div class="mt-10">
    <div class="text-3xl w-full font-bold mb-5">Academic & School Projects</div>
  </div>

  {schoolProjects.length === 0 ? (
    <p class="text-base-content/50 italic mb-5">No projects found.</p>
  ) : (
    schoolProjects.map((project) => (
      <>
        <HorizontalCard
          title={project.title}
          img={project.cover_image ? pb.files.getUrl(project, project.cover_image) : "/post_img.webp"}
          desc={project.description}
          url={`/projects/${project.id}`}
          badge={project.is_featured ? "Featured" : undefined}
        />
        <div class="divider my-0" />
      </>
    ))
  )}
</BaseLayout>

