---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pb } from "../../lib/pocketbase";

export async function getStaticPaths() {
  try {
    const projects = await pb.collection("projects").getFullList();
    return projects.map((project) => ({
      params: { id: project.id },
    }));
  } catch (e) {
    console.error("Failed to generate static paths for projects:", e);
    return [];
  }
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/404");
}

let project: any = {};
try {
  project = await pb.collection("projects").getOne(id);
} catch (e) {
  console.error(`Failed to fetch project ${id}:`, e);
}

if (!project || !project.id) {
  return Astro.redirect("/404");
}

let techStack: any[] = [];
if (project.tech_stack) {
  try {
    techStack = Array.isArray(project.tech_stack)
      ? project.tech_stack
      : JSON.parse(project.tech_stack);
  } catch {
    if (typeof project.tech_stack === "string") {
      try {
        techStack = JSON.parse(project.tech_stack.replace(/'/g, '"'));
      } catch {
        techStack = [project.tech_stack];
      }
    }
  }
}

let extraLinks: any[] = [];
if (project.links) {
  try {
    extraLinks = Array.isArray(project.links)
      ? project.links
      : JSON.parse(project.links);
  } catch {
    if (typeof project.links === "string") {
      try {
        extraLinks = JSON.parse(project.links.replace(/'/g, '"'));
      } catch {
        // ignore
      }
    }
  }
}

let coverUrl = project.cover_image_url || null;
if (!coverUrl && project.cover_image) {
  coverUrl = project.cover_image.startsWith("http://") || project.cover_image.startsWith("https://")
    ? project.cover_image
    : pb.files.getUrl(project, project.cover_image);
}

// Resolve multiple videos
const videoUrls: any[] = [];
if (project.videos) {
  const list = Array.isArray(project.videos)
    ? project.videos
    : [project.videos];
  list.forEach((vid: any) => {
    if (vid) {
      if (typeof vid === "string" && (vid.startsWith("http://") || vid.startsWith("https://"))) {
        videoUrls.push(vid);
      } else {
        videoUrls.push(pb.files.getUrl(project, vid));
      }
    }
  });
}
if (project.video_links) {
  try {
    const linksList = Array.isArray(project.video_links)
      ? project.video_links
      : JSON.parse(project.video_links);
    linksList.forEach((linkUrl: any) => {
      if (linkUrl && typeof linkUrl === "string" && linkUrl.trim()) {
        videoUrls.push(linkUrl.trim());
      }
    });
  } catch {
    if (typeof project.video_links === "string" && project.video_links.trim()) {
      videoUrls.push(project.video_links.trim());
    }
  }
}

let longFormVideoUrl = project.long_form_video_link || null;
if (!longFormVideoUrl && project.long_form_video) {
  longFormVideoUrl = project.long_form_video.startsWith("http://") || project.long_form_video.startsWith("https://")
    ? project.long_form_video
    : pb.files.getUrl(project, project.long_form_video);
}

function getMediaDetails(url: string) {
  if (!url) return null;
  
  // YouTube
  const ytMatch = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/i);
  if (ytMatch && ytMatch[1]) {
    return {
      type: 'youtube',
      embedUrl: `https://www.youtube.com/embed/${ytMatch[1]}`,
    };
  }

  // Vimeo
  const vimeoMatch = url.match(/(?:vimeo\.com\/)(?:channels\/[^\/]+\/|groups\/[^\/]+\/album\/\d+\/video\/|showcase\/[^\/]+\/video\/|video\/|)(\d+)/i);
  if (vimeoMatch && vimeoMatch[1]) {
    return {
      type: 'vimeo',
      embedUrl: `https://player.vimeo.com/video/${vimeoMatch[1]}`,
    };
  }

  // Check extensions
  const cleanUrl = url.split('?')[0].toLowerCase();
  if (cleanUrl.endsWith('.gif')) {
    return { type: 'gif', url };
  }
  if (cleanUrl.endsWith('.mp4') || cleanUrl.endsWith('.webm') || cleanUrl.endsWith('.ogg') || cleanUrl.endsWith('.mov')) {
    return { type: 'video', url };
  }
  if (cleanUrl.endsWith('.jpg') || cleanUrl.endsWith('.jpeg') || cleanUrl.endsWith('.png') || cleanUrl.endsWith('.webp') || cleanUrl.endsWith('.svg')) {
    return { type: 'image', url };
  }

  // Default fallback
  if (url.includes('/api/files/')) {
    return { type: 'video', url };
  }

  return { type: 'video', url };
}
---

<BaseLayout
  title={project.title}
  sideBarActiveItemID="projects"
  currentPath={`/projects/${project.id}`}
>
  <div class="space-y-6">
    <!-- Cover Image -->
    {
      coverUrl && (
        <div class="w-full h-80 overflow-hidden rounded-xl shadow-md bg-neutral">
          <img
            src={coverUrl}
            alt={`${project.title} Cover`}
            class="w-full h-full object-cover"
          />
        </div>
      )
    }

    <!-- Title and Meta -->
    <div
      class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-neutral pb-4"
    >
      <div>
        <h1 class="text-4xl font-bold flex items-center gap-2">
          {project.title}
        </h1>
        <div
          class="text-sm text-base-content/60 mt-1 flex flex-wrap items-center gap-3"
        >
          <span class="badge badge-outline capitalize"
            >{
              project.project_type === "forfun"
                ? "For Fun"
                : project.project_type
            }</span
          >
          {project.timeline && <span>{project.timeline}</span>}
        </div>
      </div>

      <!-- Primary Links -->
      <div class="flex items-center gap-2">
        {
          project.github_link && (
            <a
              href={project.github_link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-outline btn-sm"
            >
              <svg class="h-4 w-4 fill-current mr-1" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>
          )
        }
        {
          project.website_link && (
            <a
              href={project.website_link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-primary btn-sm"
            >
              Live Demo
            </a>
          )
        }
      </div>
    </div>

    <!-- Tech Stack badges -->
    {
      techStack.length > 0 && (
        <div>
          <h2 class="text-sm font-semibold uppercase opacity-60 mb-2">
            Tech Stack
          </h2>
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="badge badge-neutral">{tech}</span>
            ))}
          </div>
        </div>
      )
    }

    <!-- Description -->
    {
      project.description && (
        <div class="prose max-w-none text-base-content/85">
          <h2 class="text-xl font-bold mb-2">About the Project</h2>
          <p class="whitespace-pre-line leading-relaxed">
            {project.description}
          </p>
        </div>
      )
    }

    <!-- Extra Links -->
    {
      extraLinks.length > 0 && (
        <div class="border-t border-neutral pt-4">
          <h2 class="text-xl font-bold mb-3">Links & Resources</h2>
          <ul class="list-disc list-inside space-y-1 text-primary">
            {extraLinks.map((link: any) => (
              <li>
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="hover:underline"
                >
                  {link.label || link.url}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <!-- Videos section -->
    {
      videoUrls.length > 0 && (
        <div class="border-t border-neutral pt-6 space-y-4">
          <h2 class="text-xl font-bold">Project Demos</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {videoUrls.map((videoUrl, index) => {
              const media = getMediaDetails(videoUrl);
              return (
                <div class="space-y-1">
                  <span class="text-xs opacity-60 font-mono">
                    Demo Media #{index + 1}
                  </span>
                  {media?.type === 'youtube' || media?.type === 'vimeo' ? (
                    <iframe
                      src={media.embedUrl}
                      class="w-full aspect-video rounded-lg shadow border border-neutral/50 bg-neutral/20"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                      allowfullscreen
                    />
                  ) : media?.type === 'gif' || media?.type === 'image' ? (
                    <img
                      src={media.url}
                      alt={`Demo Media #${index + 1}`}
                      class="w-full rounded-lg shadow border border-neutral/50 bg-neutral/20 object-cover aspect-video"
                    />
                  ) : (
                    <video
                      src={media?.url}
                      controls
                      class="w-full rounded-lg shadow border border-neutral/50 bg-neutral/20 aspect-video"
                    />
                  )}
                </div>
              );
            })}
          </div>
        </div>
      )
    }

    <!-- Long form video section -->
    {
      longFormVideoUrl && (
        <div class="border-t border-neutral pt-6 space-y-3">
          <h2 class="text-xl font-bold">Full Video Walkthrough</h2>
          <div class="w-full font-sans">
            {(() => {
              const media = getMediaDetails(longFormVideoUrl);
              if (media?.type === 'youtube' || media?.type === 'vimeo') {
                return (
                  <iframe
                    src={media.embedUrl}
                    class="w-full aspect-video rounded-lg shadow-md border border-neutral bg-neutral/20"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen
                  />
                );
              } else if (media?.type === 'gif' || media?.type === 'image') {
                return (
                  <img
                    src={media.url}
                    alt="Walkthrough"
                    class="w-full rounded-lg shadow-md border border-neutral bg-neutral/20"
                  />
                );
              } else {
                return (
                  <video
                    src={media?.url}
                    controls
                    class="w-full rounded-lg shadow-md border border-neutral bg-neutral/20"
                  />
                );
              }
            })()}
          </div>
        </div>
      )
    }
  </div>
</BaseLayout>
