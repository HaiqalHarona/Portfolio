---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { pb } from "../../lib/pocketbase";

export async function getStaticPaths() {
  try {
    const projects = await pb.collection("projects").getFullList();
    return projects.map((project) => ({
      params: { id: project.id },
    }));
  } catch (e) {
    console.error("Failed to generate static paths for projects:", e);
    return [];
  }
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect("/404");
}

let project: any = {};
try {
  project = await pb.collection("projects").getOne(id);
} catch (e) {
  console.error(`Failed to fetch project ${id}:`, e);
}

if (!project || !project.id) {
  return Astro.redirect("/404");
}

let techStack: any[] = [];
if (project.tech_stack) {
  try {
    techStack = Array.isArray(project.tech_stack)
      ? project.tech_stack
      : JSON.parse(project.tech_stack);
  } catch {
    if (typeof project.tech_stack === "string") {
      try {
        techStack = JSON.parse(project.tech_stack.replace(/'/g, '"'));
      } catch {
        techStack = [project.tech_stack];
      }
    }
  }
}

let extraLinks: any[] = [];
if (project.links) {
  let parsedLinks: any = project.links;
  
  if (typeof project.links === 'string') {
    try {
      parsedLinks = JSON.parse(project.links.replace(/'/g, '"'));
    } catch {
      if (project.links.trim()) {
        parsedLinks = [project.links.trim()];
      }
    }
  }

  if (Array.isArray(parsedLinks)) {
    extraLinks = parsedLinks;
  } else if (parsedLinks && typeof parsedLinks === 'object') {
    if (parsedLinks.url) {
      extraLinks = [parsedLinks];
    } else {
      for (const [key, val] of Object.entries(parsedLinks)) {
        if (typeof val === 'string' && (val.startsWith('http') || val.startsWith('/'))) {
          extraLinks.push({ url: val, label: key });
        } else if (typeof key === 'string' && (key.startsWith('http') || key.startsWith('/'))) {
          extraLinks.push({ url: key, label: val });
        }
      }
    }
  }
}

let coverUrl = project.cover_image_url || null;
if (!coverUrl && project.cover_image) {
  coverUrl = project.cover_image.startsWith("http://") || project.cover_image.startsWith("https://")
    ? project.cover_image
    : pb.files.getUrl(project, project.cover_image);
}

// Resolve multiple videos
const videoUrls: { url: string; header: string }[] = [];
if (project.videos) {
  const list = Array.isArray(project.videos)
    ? project.videos
    : [project.videos];
    
  let headersData: any = null;
  if (project.video_headers) {
    try {
      headersData = typeof project.video_headers === 'string'
        ? JSON.parse(project.video_headers)
        : project.video_headers;
    } catch {
      headersData = null;
    }
  }

  list.forEach((vid: any, idx: number) => {
    if (vid) {
      let url = "";
      let vidName = "";
      if (typeof vid === "string" && (vid.startsWith("http://") || vid.startsWith("https://"))) {
        url = vid;
        vidName = vid;
      } else {
        url = pb.files.getUrl(project, vid);
        vidName = typeof vid === "string" ? vid : "";
      }
      
      let header = `Demo Video #${idx + 1}`;
      if (headersData) {
        if (Array.isArray(headersData)) {
          if (headersData[idx]) header = headersData[idx];
        } else if (typeof headersData === 'object') {
          for (const [key, val] of Object.entries(headersData)) {
            if (vidName.toLowerCase().includes(key.toLowerCase())) {
              header = val as string;
              break;
            }
          }
        }
      }
      
      videoUrls.push({ url, header });
    }
  });
}
if (project.video_links) {
  try {
    const linksList = Array.isArray(project.video_links)
      ? project.video_links
      : JSON.parse(project.video_links);
    linksList.forEach((linkUrl: any, idx: number) => {
      if (linkUrl && typeof linkUrl === "string" && linkUrl.trim()) {
        videoUrls.push({ url: linkUrl.trim(), header: `External Demo #${idx + 1}` });
      }
    });
  } catch {
    if (typeof project.video_links === "string" && project.video_links.trim()) {
      videoUrls.push({ url: project.video_links.trim(), header: `External Demo` });
    }
  }
}

let longFormVideoUrl = project.long_form_video_link || null;
if (!longFormVideoUrl && project.long_form_video) {
  longFormVideoUrl = project.long_form_video.startsWith("http://") || project.long_form_video.startsWith("https://")
    ? project.long_form_video
    : pb.files.getUrl(project, project.long_form_video);
}

// Resolve multiple images
const imageUrls: { url: string; header: string }[] = [];
if (project.images) {
  const list = Array.isArray(project.images)
    ? project.images
    : [project.images];
  
  let headersData: any = null;
  if (project.image_headers) {
    try {
      headersData = typeof project.image_headers === 'string'
        ? JSON.parse(project.image_headers)
        : project.image_headers;
    } catch {
      // Fallback if invalid JSON
      headersData = null;
    }
  }

  list.forEach((img: any, idx: number) => {
    if (img) {
      let url = "";
      let imgName = "";
      if (typeof img === "string" && (img.startsWith("http://") || img.startsWith("https://"))) {
        url = img;
        imgName = img;
      } else {
        url = pb.files.getUrl(project, img);
        imgName = typeof img === "string" ? img : "";
      }
      
      let header = `Image #${idx + 1}`;
      if (headersData) {
        if (Array.isArray(headersData)) {
          if (headersData[idx]) header = headersData[idx];
        } else if (typeof headersData === 'object') {
          // If it's a JSON object, match the key to part of the image filename
          for (const [key, val] of Object.entries(headersData)) {
            if (imgName.toLowerCase().includes(key.toLowerCase())) {
              header = val as string;
              break;
            }
          }
        }
      }

      imageUrls.push({ url, header });
    }
  });
}

function getMediaDetails(url: string) {
  if (!url) return null;
  
  // YouTube
  const ytMatch = url.match(/(?:youtube\.com\/(?:[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([^"&?\/\s]{11})/i);
  if (ytMatch && ytMatch[1]) {
    return {
      type: 'youtube',
      embedUrl: `https://www.youtube.com/embed/${ytMatch[1]}`,
    };
  }

  // Vimeo
  const vimeoMatch = url.match(/(?:vimeo\.com\/)(?:channels\/[^\/]+\/|groups\/[^\/]+\/album\/\d+\/video\/|showcase\/[^\/]+\/video\/|video\/|)(\d+)/i);
  if (vimeoMatch && vimeoMatch[1]) {
    return {
      type: 'vimeo',
      embedUrl: `https://player.vimeo.com/video/${vimeoMatch[1]}`,
    };
  }

  // Check extensions
  const cleanUrl = url.split('?')[0].toLowerCase();
  if (cleanUrl.endsWith('.gif')) {
    return { type: 'gif', url };
  }
  if (cleanUrl.endsWith('.mp4') || cleanUrl.endsWith('.webm') || cleanUrl.endsWith('.ogg') || cleanUrl.endsWith('.mov')) {
    return { type: 'video', url };
  }
  if (cleanUrl.endsWith('.jpg') || cleanUrl.endsWith('.jpeg') || cleanUrl.endsWith('.png') || cleanUrl.endsWith('.webp') || cleanUrl.endsWith('.svg')) {
    return { type: 'image', url };
  }

  // Default fallback
  if (url.includes('/api/files/')) {
    return { type: 'video', url };
  }

  return { type: 'video', url };
}
---

<BaseLayout
  title={project.title}
  sideBarActiveItemID="projects"
  currentPath={`/projects/${project.id}`}
>
  <div class="space-y-12 font-mono max-w-4xl mx-auto">
    
    <!-- Free Header -->
    <div class="mb-4">
      <h1 class="text-4xl md:text-5xl font-bold text-primary mb-4">./{project.title}</h1>
      <div class="flex flex-wrap gap-4 text-sm opacity-80">
        <span class="text-accent">type: {project.project_type}</span>
        {project.timeline && <span class="text-neutral-content">date: {project.timeline}</span>}
      </div>
    </div>

    <!-- Description -->
    {project.description && (
      <div class="border border-neutral rounded-xl overflow-hidden bg-[#0a0a0a] shadow-[0_0_15px_rgba(34,211,238,0.05)]">
        <div class="bg-neutral/30 px-4 py-1 text-[10px] uppercase tracking-widest opacity-60 border-b border-neutral">
          description.txt
        </div>
        <div class="p-6">
          <p class="leading-relaxed opacity-90 whitespace-pre-line">{project.description}</p>
        </div>
      </div>
    )}

    <!-- Tech Stack -->
    {techStack && techStack.length > 0 && (
      <div class="border border-neutral rounded-xl overflow-hidden bg-[#0a0a0a] shadow-[0_0_15px_rgba(34,211,238,0.05)]">
        <div class="bg-neutral/30 px-4 py-1 text-[10px] uppercase tracking-widest opacity-60 border-b border-neutral">
          tech_stack.json
        </div>
        <div class="p-6">
          <div class="flex flex-wrap gap-2">
            {techStack.map((tech) => (
              <span class="text-primary hover:text-accent cursor-default transition-colors">[{tech}]</span>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Media Grid -->
    {(videoUrls.length > 0 || imageUrls.length > 0) && (
      <div class="border border-neutral rounded-xl overflow-hidden bg-[#0a0a0a] shadow-[0_0_15px_rgba(34,211,238,0.05)]">
        <div class="bg-neutral/30 px-4 py-1 text-[10px] uppercase tracking-widest opacity-60 border-b border-neutral">
          media_gallery.sh
        </div>
        <div class="p-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {videoUrls.map((videoObj, idx) => {
              const media = getMediaDetails(videoObj.url);
              const totalMedia = videoUrls.length + imageUrls.length;
              const isFeatured = idx === 0 && (totalMedia === 1 || totalMedia % 2 !== 0);
              const colSpanClass = isFeatured ? "md:col-span-2" : "md:col-span-1";
              
              return (
                <div class={`relative group flex flex-col ${colSpanClass}`}>
                  <div class="absolute -inset-0.5 bg-gradient-to-r from-primary/30 to-accent/30 blur opacity-0 group-hover:opacity-100 transition duration-500 rounded-xl"></div>
                  <div class="relative bg-black rounded-xl overflow-hidden border border-neutral/50 shadow-sm flex flex-col flex-grow">
                    <div class="bg-neutral/20 px-3 py-1.5 text-[10px] border-b border-neutral/50 flex items-center justify-between">
                       <div class="flex space-x-1.5">
                         <div class="w-2 h-2 rounded-full bg-neutral-content/20"></div>
                         <div class="w-2 h-2 rounded-full bg-neutral-content/20"></div>
                         <div class="w-2 h-2 rounded-full bg-neutral-content/20"></div>
                       </div>
                       <span class="opacity-40 font-mono tracking-wider">viewing: {videoObj.header || `video_${idx}.mp4`}</span>
                    </div>
                    {media?.type === 'youtube' || media?.type === 'vimeo' ? (
                      <iframe src={media.embedUrl} class="w-full aspect-video flex-grow" allowfullscreen />
                    ) : media?.type === 'gif' || media?.type === 'image' ? (
                      <img src={media.url} class="w-full aspect-video object-cover flex-grow" />
                    ) : (
                      <video src={media?.url} controls class="w-full aspect-video flex-grow" />
                    )}
                  </div>
                  {videoObj.header && <span class="text-xs text-primary/70 mt-2 font-mono w-full">> {videoObj.header}</span>}
                </div>
              );
            })}
            
            {imageUrls.map((img, idx) => {
               const totalMedia = videoUrls.length + imageUrls.length;
               const isFeatured = videoUrls.length === 0 && idx === 0 && (totalMedia === 1 || totalMedia % 2 !== 0);
               const colSpanClass = isFeatured ? "md:col-span-2" : "md:col-span-1";

               return (
                 <div class={`relative group flex flex-col ${colSpanClass}`}>
                   <div class="absolute -inset-0.5 bg-gradient-to-r from-primary/30 to-accent/30 blur opacity-0 group-hover:opacity-100 transition duration-500 rounded-xl"></div>
                   <div class="relative bg-black rounded-xl overflow-hidden border border-neutral/50 shadow-sm flex flex-col flex-grow">
                     <div class="bg-neutral/20 px-3 py-1.5 text-[10px] border-b border-neutral/50 flex items-center justify-between">
                       <div class="flex space-x-1.5">
                         <div class="w-2 h-2 rounded-full bg-neutral-content/20"></div>
                         <div class="w-2 h-2 rounded-full bg-neutral-content/20"></div>
                         <div class="w-2 h-2 rounded-full bg-neutral-content/20"></div>
                       </div>
                       <span class="opacity-40 font-mono tracking-wider">viewing: {img.header || `image_${idx}.png`}</span>
                     </div>
                     <img src={img.url} alt={img.header} class="w-full h-auto object-contain flex-grow bg-neutral/10" style={isFeatured ? "max-height: 700px;" : "max-height: 400px;"} />
                   </div>
                   {img.header && <span class="text-xs text-primary/70 mt-2 font-mono w-full">> {img.header}</span>}
                 </div>
               );
            })}
          </div>
        </div>
      </div>
    )}

    <!-- Resources -->
    {extraLinks && extraLinks.length > 0 && (
      <div class="border border-neutral rounded-xl overflow-hidden bg-[#0a0a0a] shadow-[0_0_15px_rgba(34,211,238,0.05)]">
        <div class="bg-neutral/30 px-4 py-1 text-[10px] uppercase tracking-widest opacity-60 border-b border-neutral">
          resources.sh
        </div>
        <div class="p-6">
          <ul class="space-y-2">
            {extraLinks.map((link: any) => (
              <li class="flex items-center gap-2">
                <span class="text-primary">$</span>
                <a href={link.url} target="_blank" class="hover:text-accent hover:underline">{link.label || link.url}</a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    )}
  </div>
</BaseLayout>
